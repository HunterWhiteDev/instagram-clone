[{"E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\index.js":"1","E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\App.js":"2","E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\reportWebVitals.js":"3","E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\Post.js":"4","E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\firebase.js":"5","E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\ImageUpload.js":"6"},{"size":500,"mtime":499162500000,"results":"7","hashOfConfig":"8"},{"size":4737,"mtime":1611681726645,"results":"9","hashOfConfig":"8"},{"size":362,"mtime":499162500000,"results":"10","hashOfConfig":"8"},{"size":2356,"mtime":1611682520197,"results":"11","hashOfConfig":"8"},{"size":559,"mtime":1611594950303,"results":"12","hashOfConfig":"8"},{"size":1896,"mtime":1611690296014,"results":"13","hashOfConfig":"8"},{"filePath":"14","messages":"15","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"16"},"1msfpjv",{"filePath":"17","messages":"18","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"19","usedDeprecatedRules":"16"},{"filePath":"20","messages":"21","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"16"},{"filePath":"22","messages":"23","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"24","messages":"25","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"16"},{"filePath":"26","messages":"27","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\index.js",[],["28","29"],"E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\App.js",["30"],"import React, { useState, useEffect } from \"react\";\r\nimport \"./App.css\";\r\nimport Post from \"./Post\";\r\nimport { auth, db } from \"./firebase\";\r\nimport { Button, Input, makeStyles, Modal } from \"@material-ui/core\";\r\nimport ImageUpload from \"./ImageUpload\";\r\n\r\nfunction App() {\r\n  const [open, setOpen] = useState();\r\n  const [openSignIn, setOpenSignIn] = useState();\r\n  const [username, setUsername] = useState();\r\n  const [password, setPassword] = useState();\r\n  const [email, setEmail] = useState();\r\n  const [posts, setPosts] = useState([]);\r\n  const [user, setUser] = useState(null);\r\n\r\n  useEffect(() => {\r\n    const unsubscribe = auth.onAuthStateChanged((authUser) => {\r\n      if (authUser) {\r\n        console.log(authUser);\r\n        setUser(authUser);\r\n        if (authUser.displayName) {\r\n          //no update\r\n        } else {\r\n          return authUser.updateProfile({ displayName: username });\r\n        }\r\n      } else {\r\n        setUser(null);\r\n      }\r\n    });\r\n    return () => {\r\n      unsubscribe();\r\n    };\r\n  }, [user, username]);\r\n\r\n  useEffect(() => {\r\n    db.collection(\"posts\")\r\n      .orderBy(\"timestamp\", \"desc\")\r\n      .onSnapshot((snapshot) => {\r\n        setPosts(\r\n          snapshot.docs.map((doc) => ({\r\n            id: doc.id,\r\n            post: doc.data(),\r\n          }))\r\n        );\r\n      });\r\n  }, []);\r\n\r\n  const signUp = (event) => {\r\n    event.preventDefault();\r\n    auth\r\n      .createUserWithEmailAndPassword(email, password)\r\n      .catch((error) => alert(error.message));\r\n  };\r\n\r\n  const signIn = (event) => {\r\n    event.preventDefault();\r\n    auth\r\n      .signInWithEmailAndPassword(email, password)\r\n      .catch((error) => alert(error.message));\r\n    setOpenSignIn(false);\r\n  };\r\n\r\n  return (\r\n    <div className=\"app\">\r\n      <Modal open={open} onClose={() => setOpen(false)}>\r\n        <div className=\"app__modal\">\r\n          <div className=\"modal__content\">\r\n            <img\r\n              className=\"app__headerImage\"\r\n              src=\"https://instagram.com/static/images/web/mobile_nav_type_logo.png/735145cfe0a4.png\"\r\n              alt=\"\"\r\n            />\r\n            <Input\r\n              type=\"text\"\r\n              placeholder=\"username\"\r\n              value={username}\r\n              onChange={(e) => setUsername(e.target.value)}\r\n            />\r\n            <Input\r\n              type=\"text\"\r\n              placeholder=\"email\"\r\n              value={email}\r\n              onChange={(e) => setEmail(e.target.value)}\r\n            />\r\n            <Input\r\n              type=\"text\"\r\n              placeholder=\"password\"\r\n              value={password}\r\n              onChange={(e) => setPassword(e.target.value)}\r\n            />\r\n            <Button onClick={signUp}>Sign Up</Button>\r\n          </div>\r\n        </div>\r\n      </Modal>\r\n\r\n      <Modal open={openSignIn} onClose={() => setOpenSignIn(false)}>\r\n        <div className=\"app__modal\">\r\n          <div className=\"modal__content\">\r\n            <img\r\n              className=\"app__headerImage\"\r\n              src=\"https://instagram.com/static/images/web/mobile_nav_type_logo.png/735145cfe0a4.png\"\r\n              alt=\"\"\r\n            />\r\n            <Input\r\n              type=\"text\"\r\n              placeholder=\"email\"\r\n              value={email}\r\n              onChange={(e) => setEmail(e.target.value)}\r\n            />\r\n            <Input\r\n              type=\"text\"\r\n              placeholder=\"password\"\r\n              value={password}\r\n              onChange={(e) => setPassword(e.target.value)}\r\n            />\r\n            <Button onClick={signIn}>Sign In</Button>\r\n          </div>\r\n        </div>\r\n      </Modal>\r\n      {/* Header */}\r\n      <div className=\"app__header\">\r\n        <img\r\n          className=\"app__headerImage\"\r\n          src=\"https://instagram.com/static/images/web/mobile_nav_type_logo.png/735145cfe0a4.png\"\r\n          alt=\"\"\r\n        />\r\n        {user ? (\r\n          <Button onClick={() => auth.signOut()}>SIGN OUT</Button>\r\n        ) : (\r\n          <div className=\"app__loginContainer\">\r\n            <Button onClick={() => setOpen(true)}>SIGN UP</Button>\r\n            <Button onClick={() => setOpenSignIn(true)}>SIGN IN</Button>\r\n          </div>\r\n        )}\r\n      </div>\r\n      <div className=\"app__posts\">\r\n        {posts.map(({ id, post }) => (\r\n          <Post\r\n            key={id}\r\n            postId={id}\r\n            username={post?.username}\r\n            imageUrl={post?.imageUrl}\r\n            caption={post?.caption}\r\n            user={user}\r\n          />\r\n        ))}\r\n      </div>\r\n\r\n      {user?.displayName ? (\r\n        <ImageUpload username={user?.displayName} />\r\n      ) : (\r\n        <h3>You need to be logged in to make a post</h3>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default App;\r\n","E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\reportWebVitals.js",[],"E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\Post.js",[],"E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\firebase.js",[],"E:\\Libraries\\Documents\\Coding Practice\\React\\instagram-clone\\src\\ImageUpload.js",[],{"ruleId":"31","replacedBy":"32"},{"ruleId":"33","replacedBy":"34"},{"ruleId":"35","severity":1,"message":"36","line":5,"column":25,"nodeType":"37","messageId":"38","endLine":5,"endColumn":35},"no-native-reassign",["39"],"no-negated-in-lhs",["40"],"no-unused-vars","'makeStyles' is defined but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]